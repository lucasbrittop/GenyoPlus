{
  "manifest_version": 3,
  "name": "Genyo Timer",
  "version": "1.0.0",
  "description": "Mostra quanto tempo falta para completar o expediente no Genyo",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "content_scripts": [{
    "matches": ["https://app.genyo.com.br/c/registroPonto*"],
    "js": ["content.js"],
    "run_at": "document_end"
  }]
}
